/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Test profile - uses nf-core/scrnaseq test-datasets (10x v2 mouse chr19 data)
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset from nf-core/scrnaseq test-datasets'

    // Limit resources for CI
    max_cpus   = 4
    max_memory = '16.GB'
    max_time   = '6.h'

    // Input data - nf-core/scrnaseq test-datasets
    input          = "${projectDir}/assets/samplesheet_test.csv"
    input_type     = 'fastq'
    technology     = '10x'
    technology_version = 'v2'

    // Reference genome from test-datasets (mouse chr19)
    fasta     = 'https://raw.githubusercontent.com/nf-core/test-datasets/scrnaseq/reference/GRCm38.p6.genome.chr19.fa'
    gtf       = 'https://raw.githubusercontent.com/nf-core/test-datasets/scrnaseq/reference/gencode.vM19.annotation.chr19.gtf'
    whitelist = 'https://raw.githubusercontent.com/nf-core/test-datasets/scrnaseq/reference/10xv2_whitelist_sub50K.txt'

    // Disable optional steps for fast testing
    run_merge       = false
    run_integration = false
    run_degs        = false
    run_gs          = false
    run_slingshot   = false
    run_vision      = false
    run_velocyto    = false
    run_fastq_screen = false
    run_rseqc       = false
    single_samples  = false

    // Use standard normalization (SCTransform has slot= API bug in Seurat 5.1.0 + SeuratObject 5.0)
    norm_type = 'standard'

    // Quick clustering settings
    resolutions     = '0.4'
    principal_components = 5

    // Very relaxed QC for test data (chr19-only reference means few features per cell)
    min_feat = 1
    max_feat = 100000
    mit_pct  = 100
    ribo_pct = 100
    min_cells_per_gene = 1
}

// Cap high-memory processes to fit within test resource limits
process {
    withLabel: 'process_high' {
        cpus   = 4
        memory = '15.GB'
    }
    withLabel: 'process_high_memory' {
        cpus   = 4
        memory = '15.GB'
    }
    // Small chr19 genome requires reduced SA index size
    withName: 'STAR_GENOMEGENERATE' {
        ext.args = '--genomeSAindexNbases 11'
    }
}
