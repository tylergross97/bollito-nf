/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    bollito-nf: single-cell RNA-seq pipeline (Nextflow port)
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Converted from the Snakemake bollito pipeline.
    https://gitlab.com/bu_cnio/bollito
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// Global default params
params {
    // ── Input/output ────────────────────────────────────────────────────────
    input           = null   // Path to samplesheet CSV
    outdir          = 'results'
    input_type      = 'fastq'   // 'fastq' or 'matrix'
    technology      = '10x'     // '10x', 'drop-seq', 'custom', or 'standard'
    technology_version = 'v3'   // '10x' only: 'v1', 'v2', or 'v3'

    // ── Reference genome ────────────────────────────────────────────────────
    fasta           = null
    gtf             = null
    star_index      = null       // Pre-built STAR index (skip indexing if provided)
    whitelist       = null       // Cell barcode whitelist (10x)
    samples_tsv     = null       // Optional path to samples.tsv with metadata columns
    multiqc_config  = null       // Optional path to multiqc_config.yaml

    // ── General ─────────────────────────────────────────────────────────────
    random_seed     = 4848
    gene_case       = 'uppercase'   // 'uppercase', 'lowercase', 'titlecase'
    write_table     = true
    single_samples  = true
    graphics        = true

    // ── Seurat QC (step 1) ──────────────────────────────────────────────────
    min_cells_per_gene = 1

    // ── Seurat post-QC filters (step 2) ─────────────────────────────────────
    min_feat        = 500
    max_feat        = 2500
    min_count       = null
    max_count       = null
    mit_pct         = 10
    ribo_pct        = 40

    // ── Seurat gene filter (step 2.1, optional) ─────────────────────────────
    filter_genes    = null   // Comma-separated gene list e.g. "CD3,CD4"
    filter_threshold = 5
    filter_out      = false

    // ── Merge & Integration (steps 2.5, 3B) ─────────────────────────────────
    run_merge       = true
    run_integration = true

    // ── Normalization (step 3) ──────────────────────────────────────────────
    norm_type       = 'SCT'     // 'SCT' or 'standard'
    variable_features = true
    regress_out     = true
    vars_to_regress = 'percent.mt'
    regress_cell_cycle  = false
    regress_merge_effect = false

    // ── Clustering (step 4) ─────────────────────────────────────────────────
    principal_components = 10
    resolutions     = '0.2,0.4,0.8,1.2,1.6'
    k_neighbors     = 20
    batch_metadata  = 'condition'

    // ── DEGs (step 5, optional) ─────────────────────────────────────────────
    run_degs        = true
    selected_cond   = '0.2,condition'
    deg_ranking     = true
    deg_test        = 'wilcox'

    // ── Gene set scoring (step 6, optional) ─────────────────────────────────
    run_gs          = true
    geneset_collection = null   // GMT file path
    geneset_percentage = 0.2

    // ── Trajectory inference (step 7, optional) ─────────────────────────────
    run_slingshot   = true
    slingshot_res   = 0.4
    start_clus      = false
    end_clus        = false
    n_var_genes     = 1000
    n_plotted_genes = 50

    // ── Vision functional analysis (step 8, optional) ───────────────────────
    run_vision      = true
    vision_geneset  = null    // GMT file path
    vision_meta_columns = 'nCount_RNA,nFeature_RNA,percent.mt,percent.ribo'
    vision_res      = 0.4

    // ── Velocyto (step 9, optional, fastq mode only) ────────────────────────
    run_velocyto    = true
    velocyto_res    = 0.4
    downsampling    = false
    downsample_n_cells = null

    // ── STAR extra params (auto-set based on technology) ────────────────────
    star_extra_args = null   // Override auto-detected STAR params

    // ── FastQ Screen (optional) ─────────────────────────────────────────────
    run_fastq_screen = false

    // ── RSeQC ───────────────────────────────────────────────────────────────
    run_rseqc       = true

    // Max resource defaults
    max_memory      = '128.GB'
    max_cpus        = 16
    max_time        = '240.h'
}

// ── Process resource defaults ───────────────────────────────────────────────
process {
    cpus   = { 1 * task.attempt }
    memory = { 8.GB * task.attempt }
    time   = { 8.h * task.attempt }

    errorStrategy = { task.exitStatus in [140,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 2

    withLabel: process_single {
        cpus   = 1
        memory = { 8.GB * task.attempt }
    }
    withLabel: process_low {
        cpus   = { 4 * task.attempt }
        memory = { 8.GB * task.attempt }
    }
    withLabel: process_medium {
        cpus   = { 4 * task.attempt }
        memory = { 16.GB * task.attempt }
    }
    withLabel: process_high {
        cpus   = { 8 * task.attempt }
        memory = { 64.GB * task.attempt }
    }
    withLabel: process_high_memory {
        cpus   = { 4 * task.attempt }
        memory = { 64.GB * task.attempt }
    }
}

// ── Profiles ────────────────────────────────────────────────────────────────
profiles {
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }
    wave {
        wave.enabled    = true
        wave.strategy   = 'conda,container'
        docker.enabled  = true
    }
    test {
        includeConfig 'conf/test.config'
    }
}

// ── Wave + conda configuration (default) ────────────────────────────────────
wave {
    enabled   = true
    strategy  = 'conda,container'
}

docker {
    enabled = true
}

// ── Manifest ────────────────────────────────────────────────────────────────
manifest {
    name            = 'bollito-nf'
    author          = 'Converted from bollito (CNIO Bioinformatics Unit)'
    description     = 'Single-cell RNA-seq pipeline: QC, alignment, quantification, clustering, DEGs, trajectory inference, RNA velocity'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=24.04.0'
    version         = '1.0.0'
}

// ── Timeline, report, trace ─────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
}
