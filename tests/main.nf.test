nextflow_pipeline {

    name "Test bollito-nf pipeline"
    script "../main.nf"
    tag "pipeline"

    test("Should run end-to-end with FASTQ test profile") {

        when {
            params {
                input              = "${projectDir}/assets/samplesheet_test.csv"
                input_type         = 'fastq'
                technology         = '10x'
                technology_version = 'v2'
                outdir             = "$outputDir"

                // Reference genome (mouse chr19 test data)
                fasta     = 'https://raw.githubusercontent.com/nf-core/test-datasets/scrnaseq/reference/GRCm38.p6.genome.chr19.fa'
                gtf       = 'https://raw.githubusercontent.com/nf-core/test-datasets/scrnaseq/reference/gencode.vM19.annotation.chr19.gtf'
                whitelist = 'https://raw.githubusercontent.com/nf-core/test-datasets/scrnaseq/reference/10xv2_whitelist_sub50K.txt'

                // Disable optional steps for fast testing
                run_merge        = false
                run_integration  = false
                run_degs         = false
                run_gs           = false
                run_slingshot    = false
                run_vision       = false
                run_velocyto     = false
                run_fastq_screen = false
                run_rseqc        = false
                single_samples   = false

                // Standard normalization (avoids Seurat v5 SCT bug)
                norm_type = 'standard'

                // Quick clustering
                resolutions          = '0.4'
                principal_components = 5

                // Relaxed QC for chr19-only test data
                min_feat           = 1
                max_feat           = 100000
                mit_pct            = 100
                ribo_pct           = 100
                min_cells_per_gene = 1
            }
        }

        then {
            assert workflow.success

            // Verify key output files exist
            assert workflow.trace.succeeded().size() > 0
            assert workflow.trace.failed().size() == 0
        }
    }
}
