/*
 * nf-test configuration for bollito-nf
 *
 * Imports the main pipeline config, then applies test-specific overrides.
 * This is loaded by nf-test automatically (see nf-test.config: configFile).
 */

// Inherit all base params, process labels, and profiles
includeConfig '../nextflow.config'

// Override params for testing
params {
    // Resource limits for CI
    max_cpus   = 4
    max_memory = '16.GB'
    max_time   = '6.h'

    // Test data - nf-core scrnaseq test-datasets (10x v2, mouse chr19)
    test_data_base = 'https://raw.githubusercontent.com/nf-core/test-datasets/scrnaseq'

    // Defaults for module-level tests
    outdir     = "${outputDir}/results"
}

// Cap process resources for test environments
process {
    withLabel: 'process_high' {
        cpus   = 4
        memory = '15.GB'
    }
    withLabel: 'process_high_memory' {
        cpus   = 4
        memory = '15.GB'
    }
    // Small chr19 genome requires reduced SA index size
    withName: 'STAR_GENOMEGENERATE' {
        ext.args = '--genomeSAindexNbases 11'
    }
}
